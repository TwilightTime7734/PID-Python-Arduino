graph TB
    subgraph UI [UI button path]
        BTN["User presses Start Auto Session"]
        BIND["Button command is bound in app.py"]
        TOGGLE["do_auto_session_toggle"]
        RUNNING{"auto_is_running?"}
        IMPORTING{"state is import_analyze?"}
        USER_ABORT["User aborts active session"]
        WAIT_PIPE["Pipeline is already running"]
        START["start_auto_session"]
        UI_ERROR["Start or toggle error"]
    end

    subgraph PREFLIGHT [Preflight and session setup]
        PREFLIGHT_CHECKS["Validate start conditions"]
        CONFIRM{"Preflight dialog confirmed?"}
        CANCELED["User cancels start"]
        INIT["Create adaptive controller and clear old session data"]
        ACTIVE_UI["Set active session UI state"]
        SCHEDULE["Schedule next auto tick"]
    end

    subgraph TELEMETRY [Continuous FC telemetry]
        POLL["poll_fc_attitude every 60 ms"]
        SAMPLE["Read latest FC attitude sample"]
        RECORD["Record auto session sample and response peaks"]
        DRAW_ATTITUDE["Update horizon and attitude text"]
    end

    subgraph LOOP [Adaptive control loop]
        TICK["run_auto_tick"]
        RUNTIME_GUARDS["Check controller, Arduino, FC, and telemetry freshness"]
        STALE_ABORT["Abort because FC telemetry is stale"]
        HAVE_SAMPLE{"Latest attitude sample available?"}
        HARD_LIMIT{"Hard safety limit exceeded?"}
        HARD_ABORT["Abort and continue pipeline"]
        RECOVERY_ENTRY{"Recovery entry limit reached?"}
        SET_RECOVERY["Enter recovery mode"]
        RECOVERY_EXIT{"Recovery complete?"}
        SET_ACTIVE["Return to adaptive run mode"]
        INFLIGHT{"Pulse command in flight?"}
        SETTLING{"Active command settling?"}
        SETTLE_DONE{"Settle time elapsed?"}
        FINALIZE_EVENT["Finalize adaptive excitation event"]
        STOP_READY{"Controller stop_ready?"}
        COMPLETE["Complete auto session"]
        NEXT_COMMAND["Request next adaptive command"]
        NO_COMMAND["No command returned"]
        ISSUE_COMMAND["Issue adaptive pulse command"]
        ISSUE_ERROR["Issue command failed"]
    end

    subgraph CONTROLLER [Adaptive controller decisions]
        SHOULD_ABORT["Abort at 45 degree hard limit"]
        SHOULD_RECOVER["Recover at 43 degrees and exit below 20 degrees"]
        CHOOSE["Choose lower-confidence axis and useful direction"]
        FORCE["Compute force, hold time, and settle time"]
        STOP_RULE["Stop after coverage targets or max runtime"]
        COVERAGE["Coverage targets for roll and pitch directions"]
    end

    subgraph COMMAND [Pulse command path]
        TARGET["Map command to output channel and target PWM"]
        MARK_ACTIVE["Track active command and baseline attitude"]
        SUBMIT_HOLD["Submit hold task to SerialWorker"]
        TASK_HOLD["Read registers and send channel hold"]
        ARDUINO["Arduino applies hold and restores output"]
        HOLD_DONE["on_auto_hold_done callback"]
        HOLD_OK{"Hold succeeded?"}
        HOLD_ABORT["Abort because pulse failed"]
        SET_SETTLE["Clear inflight pulse and schedule settling"]
    end

    subgraph ABORTS [Shared abort behavior]
        AUTO_ABORT["auto_abort completes session and updates status"]
        ABORT_COMPLETE["Cancel tick, clear command state, restore outputs"]
    end

    subgraph PIPELINE [Blackbox import and analysis pipeline]
        BEGIN_PIPE["begin_auto_pipeline"]
        PIPE_BUSY{"Blackbox import already running?"}
        PIPE_BUSY_RETURN["Show warning and return"]
        DISCONNECT_FC["Disconnect FC before MSC import"]
        IMPORT_STATE["Set import_analyze UI state"]
        SUBMIT_PULL["Submit MSC pull and import task"]
        TASK_MSC["Enter MSC mode and import Blackbox logs"]
        IMPORT_LOGS["Copy or locate logs, decode, and analyze"]
        PULL_DONE["on_auto_pull_done callback"]
        PULL_OK{"Pull returned a valid result?"}
        PULL_ABORT["Pipeline failed while pulling"]
        PICK_LOG["Pick newest imported or analyzed log"]
        HAVE_LOG{"Latest imported log exists?"}
        SUBMIT_ANALYZE_ONE["Analyze selected newest log"]
        SUBMIT_ANALYZE_ALL["Analyze pulled log directory"]
        ANALYZE_TASK["Analyze Blackbox log data"]
        ANALYZE_DONE["on_auto_analyze_done callback"]
        ANALYZE_OK{"Analysis returned a valid result?"}
        ANALYZE_ABORT["Pipeline failed while analyzing"]
        SHOW_ANALYSIS["Store and show Blackbox analysis"]
    end

    subgraph REPORT [Report generation and final UI]
        SUBMIT_REPORT["Submit auto report generation task"]
        TASK_REPORT["Resolve chart source and generate report"]
        GENERATE["Write summary files and trace viewer"]
        REPORT_DONE["on_auto_report_done callback"]
        REPORT_OK{"Report returned a valid result?"}
        REPORT_ABORT["Pipeline failed while generating report"]
        READY["Show report-ready UI"]
    end

    BTN --> BIND
    BIND --> TOGGLE
    TOGGLE --> RUNNING
    RUNNING -->|yes| USER_ABORT
    RUNNING -->|no| IMPORTING
    IMPORTING -->|yes| WAIT_PIPE
    IMPORTING -->|no| START
    START --> PREFLIGHT_CHECKS
    PREFLIGHT_CHECKS -->|failed guard| UI_ERROR
    PREFLIGHT_CHECKS -->|guards pass| CONFIRM
    CONFIRM -->|no| CANCELED
    CONFIRM -->|yes| INIT
    INIT --> ACTIVE_UI
    ACTIVE_UI --> SCHEDULE
    SCHEDULE --> TICK

    POLL --> SAMPLE
    SAMPLE --> RECORD
    SAMPLE --> DRAW_ATTITUDE
    RECORD -.-> TICK

    TICK --> RUNTIME_GUARDS
    RUNTIME_GUARDS -->|failed| STALE_ABORT
    RUNTIME_GUARDS -->|passed| HAVE_SAMPLE
    HAVE_SAMPLE -->|no| SCHEDULE
    HAVE_SAMPLE -->|yes| HARD_LIMIT
    HARD_LIMIT -.-> SHOULD_ABORT
    HARD_LIMIT -->|yes| HARD_ABORT
    HARD_LIMIT -->|no| RECOVERY_ENTRY
    RECOVERY_ENTRY -.-> SHOULD_RECOVER
    RECOVERY_ENTRY -->|yes| SET_RECOVERY
    SET_RECOVERY --> INFLIGHT
    RECOVERY_ENTRY -->|no| RECOVERY_EXIT
    RECOVERY_EXIT -->|yes| SET_ACTIVE
    SET_ACTIVE --> INFLIGHT
    RECOVERY_EXIT -->|no| INFLIGHT
    INFLIGHT -->|yes| SCHEDULE
    INFLIGHT -->|no| SETTLING
    SETTLING -->|yes| SCHEDULE
    SETTLING -->|no| SETTLE_DONE
    SETTLE_DONE -->|yes| FINALIZE_EVENT
    FINALIZE_EVENT --> STOP_READY
    SETTLE_DONE -->|no active command| STOP_READY
    STOP_READY -.-> STOP_RULE
    STOP_RULE -.-> COVERAGE
    STOP_READY -->|yes| COMPLETE
    COMPLETE --> BEGIN_PIPE
    STOP_READY -->|no| NEXT_COMMAND
    NEXT_COMMAND -.-> CHOOSE
    CHOOSE --> FORCE
    NEXT_COMMAND -->|none| NO_COMMAND
    NO_COMMAND --> SCHEDULE
    NEXT_COMMAND -->|command| ISSUE_COMMAND
    ISSUE_COMMAND -->|exception| ISSUE_ERROR
    ISSUE_COMMAND -->|submitted| TARGET
    ISSUE_ERROR --> AUTO_ABORT

    TARGET --> MARK_ACTIVE
    MARK_ACTIVE --> SUBMIT_HOLD
    SUBMIT_HOLD --> TASK_HOLD
    TASK_HOLD --> ARDUINO
    ARDUINO --> HOLD_DONE
    HOLD_DONE --> HOLD_OK
    HOLD_OK -->|no| HOLD_ABORT
    HOLD_OK -->|yes| SET_SETTLE
    SET_SETTLE --> SCHEDULE
    HOLD_ABORT --> AUTO_ABORT

    USER_ABORT --> AUTO_ABORT
    STALE_ABORT --> AUTO_ABORT
    HARD_ABORT --> AUTO_ABORT
    PULL_ABORT --> AUTO_ABORT
    ANALYZE_ABORT --> AUTO_ABORT
    REPORT_ABORT --> AUTO_ABORT
    AUTO_ABORT --> ABORT_COMPLETE
    USER_ABORT --> BEGIN_PIPE
    HARD_ABORT --> BEGIN_PIPE

    BEGIN_PIPE --> PIPE_BUSY
    PIPE_BUSY -->|yes| PIPE_BUSY_RETURN
    PIPE_BUSY -->|no| DISCONNECT_FC
    DISCONNECT_FC --> IMPORT_STATE
    IMPORT_STATE --> SUBMIT_PULL
    SUBMIT_PULL --> TASK_MSC
    TASK_MSC --> IMPORT_LOGS
    IMPORT_LOGS --> PULL_DONE
    PULL_DONE --> PULL_OK
    PULL_OK -->|no| PULL_ABORT
    PULL_OK -->|yes| PICK_LOG
    PICK_LOG --> HAVE_LOG
    HAVE_LOG -->|yes| SUBMIT_ANALYZE_ONE
    HAVE_LOG -->|no| SUBMIT_ANALYZE_ALL
    SUBMIT_ANALYZE_ONE --> ANALYZE_TASK
    SUBMIT_ANALYZE_ALL --> ANALYZE_TASK
    ANALYZE_TASK --> ANALYZE_DONE
    ANALYZE_DONE --> ANALYZE_OK
    ANALYZE_OK -->|no| ANALYZE_ABORT
    ANALYZE_OK -->|yes| SHOW_ANALYSIS
    SHOW_ANALYSIS --> SUBMIT_REPORT
    SUBMIT_REPORT --> TASK_REPORT
    TASK_REPORT --> GENERATE
    GENERATE --> REPORT_DONE
    REPORT_DONE --> REPORT_OK
    REPORT_OK -->|no| REPORT_ABORT
    REPORT_OK -->|yes| READY
